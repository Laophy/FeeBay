{
  "name": "FeeBay",
  "version": "0.1.6",
  "author": "Lake Country Games",
  "private": true,
  "description": "FeeBay Simulator — a parody marketplace card flipping game.",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "electron:dev": "vite",
    "electron:build": "tsc -b && vite build && electron-builder",
    "pack": "npm run build && electron-builder --dir",
    "package": "npm run build && electron-builder --win nsis",
    "portable": "npm run build && electron-builder --win portable",
    "steam:build": "node scripts/build-steam.mjs"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "steamworks.js": "^0.4.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "appId": "com.feebay.simulator",
    "productName": "FeeBay Simulator",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "node_modules/steamworks.js/**/*"
    ],
    "asarUnpack": [
      "node_modules/steamworks.js/**/*"
    ],
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "win": {
      "icon": "icon.ico",
      "executableName": "FeeBay",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false
    },
    "portable": {
      "artifactName": "FeeBay-Simulator-Portable-${version}.exe"
    }
  }
}
